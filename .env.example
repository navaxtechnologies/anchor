# ANCHOR environment variables.
# Copy to `.env` and fill in. NEVER commit `.env`.
# All client-exposed vars MUST be prefixed EXPO_PUBLIC_ (Expo inlines these at build).
# Secrets that must stay private (Claude API key, Stripe secret key) belong on a
# server/edge function, NOT in this file — see docs/ARCHITECTURE.md M2/M3.

# --- Supabase (M1) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- AI Life Advisor (M2) — proxied through a server; key never ships to device ---
# The app calls EXPO_PUBLIC_ADVISOR_API_URL; that server holds ANTHROPIC_API_KEY.
EXPO_PUBLIC_ADVISOR_API_URL=

# --- Stripe (M3) — publishable key only on device; secret key lives server-side ---
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- PostHog analytics (optional, no PII; app is a no-op until set) ---
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
